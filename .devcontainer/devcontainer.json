{
  "name": "greenlane-linux",
  "build": { "dockerfile": "Dockerfile" },

  // node is needed to run the prettier binary `bun install` drops into
  // web/node_modules/.bin (its shebang is `node`).
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "22" }
  },

  // The whole point of this container: reaching into another process.
  // `sys.remote_exec` (PEP 768) attaches over ptrace, so the container needs the
  // SYS_PTRACE capability and an unconfined seccomp profile. Run greenlane with
  // `sudo` inside the container (root bypasses Yama ptrace_scope), exactly like
  // the README's Linux instructions. Bump to "privileged": true if/when you test
  // perf_event_open off-CPU/CPU sampling (it also wants relaxed perf_event_paranoid).
  "runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined"],

  // Forward the greenlane server/viewer port to the host.
  "forwardPorts": [8080],

  // Use a Linux-specific virtualenv path so the container doesn't clobber (or
  // get clobbered by) the host's macOS `.venv` on the bind-mounted workspace.
  // uv honors UV_PROJECT_ENVIRONMENT for `uv sync`/`uv run`.
  "containerEnv": {
    "UV_PROJECT_ENVIRONMENT": ".venv-linux"
  },

  // One-time setup: fetch CPython 3.14, sync the dev dependency group, and install
  // the viewer's node deps. Runs as the `vscode` user so the toolchains land in
  // its home.
  "postCreateCommand": "uv python install 3.14 && uv sync --dev && bun install --cwd web && printf '\\n# auto-activate the Linux venv when present\\nif [ -f \"${containerWorkspaceFolder}/.venv-linux/bin/activate\" ]; then . \"${containerWorkspaceFolder}/.venv-linux/bin/activate\"; fi\\n' >> ~/.bashrc",

  "remoteUser": "vscode",

  // `vscode` here is the IDE/tool key (where VS Code reads its extensions), NOT a
  // username. The terminal-first `dev` CLI ignores this block.
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
